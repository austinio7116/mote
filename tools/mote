#!/usr/bin/env python3
"""
mote — the Mote dev-platform CLI.

Dev workflow (host, no device needed):
    mote new <name>           scaffold a new game folder
    mote build <dir>          compile -> host .so (+ device .mote with --device)
    mote run <dir>            build for host + launch the SDL emulator

Device control channel (USB-CDC):
    mote ping                 handshake: confirm a Mote device is connected
    mote list                 list installed games (catalog)

Add --device to build to also cross-compile the deployable .mote module.
"""
import argparse
import os
import shutil
import subprocess
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
ENGINE = os.path.join(ROOT, "engine")
SDK = os.path.join(ROOT, "sdk")

ENGINE_INCS = [os.path.join(ENGINE, d)
               for d in ("core", "math", "render", "assets", "input", "physics")] + [SDK]

ARM = "arm-none-eabi-"
ARM_ARCH = ["-mcpu=cortex-m33", "-mthumb", "-mfloat-abi=softfp", "-mfpu=fpv5-sp-d16"]

MOTE_VID, MOTE_PID = 0xCAFE, 0x4D01


# ---------------------------------------------------------------- helpers
def run(cmd):
    r = subprocess.run(cmd)
    if r.returncode != 0:
        sys.exit("mote: command failed: %s" % " ".join(cmd))


def game_name(d):
    # Source of truth: MOTE_GAME_META("name", ...) in src/game.c.
    gc = os.path.join(d, "src", "game.c")
    if os.path.isfile(gc):
        import re
        m = re.search(r'MOTE_GAME_META\s*\(\s*"([^"]*)"', open(gc, errors="replace").read())
        if m:
            return m.group(1)
    # Legacy fallback: a game.toml [game] name (older projects).
    toml = os.path.join(d, "game.toml")
    if os.path.isfile(toml):
        for line in open(toml):
            line = line.strip()
            if line.startswith("name") and "=" in line:
                return line.split("=", 1)[1].strip().strip('"').strip("'")
    return os.path.basename(os.path.abspath(d))


def game_sources(d):
    src = os.path.join(d, "src")
    if not os.path.isdir(src):
        sys.exit("mote: %s has no src/ directory" % d)
    cs = sorted(os.path.join(src, f) for f in os.listdir(src) if f.endswith(".c"))
    if not cs:
        sys.exit("mote: no .c files in %s/src" % d)
    return cs, src


def incs_flags(gamesrc):
    return ["-I" + p for p in ENGINE_INCS + [gamesrc]]


def game_cflags(d):
    """Optional per-game extra compiler flags. A `<gamedir>/cflags` file holds
    whitespace-separated tokens (e.g. -DCRAFT_TEXTURES_BAKED=1); '#' comment
    lines are ignored. Used by vendored ports that need build-time defines.
    Applied to both the host and device compiles so the two stay in sync."""
    f = os.path.join(d, "cflags")
    if not os.path.isfile(f):
        return []
    toks = []
    for line in open(f):
        line = line.split("#", 1)[0].strip()
        if line:
            toks += line.split()
    return toks


# ---------------------------------------------------------------- build
def build_host(d, name, srcs, gamesrc, outdir):
    """A game module is a .so that links NO engine code — it reaches the
    engine only through the ABI it is handed (device analogue: a .mote)."""
    out = os.path.join(outdir, name + ".so")
    cmd = ["gcc", "-shared", "-fPIC", "-O2", "-ffast-math", "-Wno-format-truncation", "-DMOTE_HOST=1"]
    cmd += game_cflags(d) + incs_flags(gamesrc) + srcs + ["-lm", "-o", out]
    run(cmd)
    return out


def build_device(d, name, srcs, gamesrc, outdir):
    """Cross-compile to a deployable .mote: linked at the fixed virtual window
    via sdk/game.ld, no engine/crt0 — talks to the engine only via the ABI."""
    if not shutil.which(ARM + "gcc"):
        sys.exit("mote: %sgcc not found (install gcc-arm-none-eabi)" % ARM)
    objs = []
    base = ["-O2", "-ffast-math", "-ffreestanding", "-fno-common",
            "-ffunction-sections", "-fdata-sections", "-Wno-format-truncation",
            "-DMOTE_DEVICE=1", "-DMOTE_MODULE_BUILD=1"] + game_cflags(d)
    for c in srcs:
        o = os.path.join(outdir, os.path.basename(c) + ".o")
        run([ARM + "gcc"] + ARM_ARCH + base + incs_flags(gamesrc) + ["-c", c, "-o", o])
        objs.append(o)
    elf = os.path.join(outdir, name + ".elf")
    # mote_syscalls.c supplies the libc syscall stubs (_read/_write/_close/_fstat/
    # _sbrk/…) that newlib's snprintf/printf family reference through its FILE
    # machinery. The game never does real I/O, so the stubs just fail — they exist
    # only to satisfy the linker so games can use snprintf for HUD text.
    sysobj = os.path.join(outdir, "mote_syscalls.c.o")
    run([ARM + "gcc"] + ARM_ARCH + base + ["-c", os.path.join(SDK, "mote_syscalls.c"), "-o", sysobj])
    run([ARM + "gcc"] + ARM_ARCH + ["-nostartfiles",
        "-T", os.path.join(SDK, "game.ld"), "-Wl,--gc-sections"]
        + objs + [sysobj, "-lm", "-lgcc", "-o", elf])
    mote = os.path.join(outdir, name + ".mote")
    run([ARM + "objcopy", "-O", "binary", "-j", ".mote", "-j", ".data", "-j", ".ramtext", elf, mote])
    return mote


def cmd_build(args):
    d = args.dir
    name = game_name(d)
    srcs, gamesrc = game_sources(d)
    outdir = os.path.join(d, "build")
    os.makedirs(outdir, exist_ok=True)
    so = build_host(d, name, srcs, gamesrc, outdir)
    print("built host module: %s" % so)
    if args.device:
        mote = build_device(d, name, srcs, gamesrc, outdir)
        print("built device module: %s (%d bytes)" % (mote, os.path.getsize(mote)))
    return so


def _magick():
    """Return (convert_cmd, identify_cmd) for IM7 (`magick`) or IM6 (`convert`)."""
    import shutil
    if shutil.which("magick"):  return (["magick"], ["magick", "identify"])
    if shutil.which("convert"): return (["convert"], ["identify"])
    sys.exit("mote: ImageMagick (magick/convert) needed to bake images")

def bake_image(name, path, out):
    """PNG/BMP -> a MoteImage header: <name>_px[] RGB565 + <name>_img.

    Alpha < 128 becomes the magenta colour-key (transparent); the image's key is
    set so the 2D rasteriser/blit skips it."""
    import subprocess
    conv, ident = _magick()
    w, h = subprocess.check_output(ident + ["-format", "%w %h", path]).split()
    w, h = int(w), int(h)
    raw = subprocess.check_output(conv + [path, "-depth", "8", "RGBA:-"])
    KEY = 0xF81F
    px = []
    keyed = False
    for i in range(w * h):
        r, g, b, a = raw[i*4], raw[i*4+1], raw[i*4+2], raw[i*4+3]
        if a < 128:
            px.append(KEY); keyed = True
        else:
            v = ((r >> 3) << 11) | ((g >> 2) << 5) | (b >> 3)
            px.append(0xF81E if v == KEY else v)   # nudge real magenta off the key
    L = ['/* GENERATED by mote bake (img2tex) from %s — do not edit. */' % os.path.basename(path),
         '#ifndef MOTE_IMG_%s_H' % name, '#define MOTE_IMG_%s_H' % name,
         '#include "mote_2d.h"', '',
         'static const uint16_t %s_px[%d] = {' % (name, w*h)]
    for i in range(0, len(px), 16):
        L.append('  ' + ','.join('0x%04x' % v for v in px[i:i+16]) + ',')
    L += ['};',
          'static const MoteImage %s_img = { %s_px, %d, %d, 0x%04X, %d };' % (name, name, w, h, KEY, 0 if keyed else 1),
          '#define %s_W %d' % (name, w), '#define %s_H %d' % (name, h), '', '#endif']
    open(out, "w").write('\n'.join(L))
    print("[img2tex] %s: %dx%d -> %s" % (name, w, h, out))

def _icon_encode(px):
    """RGB565 pixels -> a compact paletted blob (matches sdk/mote_icon.h):
    [u8 bpp][u8 0][u16 npal][u16 pal[npal]][packed indices, MSB-first].
    Lossless when <=256 colours, else an RGB332 256-colour quantise."""
    pal, idx = [], []
    seen = {}
    over = False
    for c in px:
        j = seen.get(c)
        if j is None:
            if len(pal) < 256:
                j = len(pal); seen[c] = j; pal.append(c)
            else:
                over = True; break
        idx.append(j)
    if over:
        pal = []
        for q in range(256):
            r3, g3, b2 = (q >> 5) & 7, (q >> 2) & 7, q & 3
            r5 = (r3 << 2) | (r3 >> 1); g6 = (g3 << 3); b5 = (b2 << 3) | (b2 << 1)
            pal.append((r5 << 11) | ((g6 & 63) << 5) | b5)
        idx = []
        for c in px:
            r5, g6, b5 = (c >> 11) & 31, (c >> 5) & 63, c & 31
            idx.append(((r5 >> 2) << 5) | ((g6 >> 3) << 2) | (b5 >> 3))
    npal = len(pal)
    bpp = 1 if npal <= 2 else 2 if npal <= 4 else 4 if npal <= 16 else 8
    out = bytearray([bpp, 0, npal & 0xFF, npal >> 8])
    for c in pal:
        out += bytes([c & 0xFF, c >> 8])
    if bpp == 8:
        out += bytes(idx)
    else:
        per = 8 // bpp; acc = 0; filled = 0
        for v in idx:
            acc = (acc << bpp) | (v & ((1 << bpp) - 1)); filled += 1
            if filled == per: out.append(acc & 0xFF); acc = 0; filled = 0
        if filled: out.append((acc << ((per - filled) * bpp)) & 0xFF)
    return out

def bake_icon(path, out):
    """icon.png/.bmp -> src/icon.h : a compact paletted `mote_game_icon_data[]` blob
    (sdk/mote_icon.h), the launcher icon that travels in the game module."""
    import subprocess
    conv, _ = _magick()
    raw = subprocess.check_output(conv + [path, "-resize", "60x60!", "-depth", "8", "RGBA:-"])
    px = [((raw[i*4] >> 3) << 11) | ((raw[i*4+1] >> 2) << 5) | (raw[i*4+2] >> 3) for i in range(60*60)]
    blob = _icon_encode(px)
    L = ['/* GENERATED launcher icon — compact paletted blob (sdk/mote_icon.h),',
         ' * %d bytes vs 7200 raw. Regenerate with `mote bake` (icon.png). */' % len(blob),
         '#ifndef MOTE_GAME_ICON_H', '#define MOTE_GAME_ICON_H', '#include <stdint.h>', '',
         'const uint8_t mote_game_icon_data[%d] __attribute__((weak)) = {' % len(blob)]
    for i in range(0, len(blob), 16):
        L.append('  ' + ','.join('0x%02x' % v for v in blob[i:i+16]) + ',')
    L += ['};', '', '#endif']
    open(out, "w").write('\n'.join(L) + '\n')
    print("[icon] %s -> %s (%d bytes, was 7200)" % (os.path.basename(path), out, len(blob)))

def bake_sfx(name, path, out):
    """assets/<name>.sfx (editable recipe sidecar) -> src/<name>.sfx.h : a
    `static const MoteSfx <name>_sfx` the game synthesises with mote_sfx_bake().
    The .sfx text format + the header field order match Mote Studio's Audio tab,
    so a sound round-trips: author in Studio -> .sfx + .sfx.h, or hand-edit the
    .sfx and re-bake. Field order matches MoteSfx exactly."""
    v = {"wave":0, "base":0.0,"limit":0.0,"ramp":0.0,"dramp":0.0, "duty":0.5,"duty_ramp":0.0,
         "vibs":0.0,"vibspd":0.0, "atk":0.0,"sus":0.3,"punch":0.0,"dec":0.4,
         "lpf":1.0,"lpr":0.0,"lres":0.0, "hpf":0.0,"hpr":0.0, "pho":0.0,"phr":0.0, "arps":0.0,"arpm":0.0}
    with open(path) as fh:
        for line in fh:
            line = line.strip()
            if not line or line[0] == "#": continue
            t = line.split(); k = t[0]; n = [float(x) for x in t[1:]] if len(t) > 1 else []
            if   k == "wave": v["wave"] = int(n[0])
            elif k == "freq" and len(n) >= 4: v["base"],v["limit"],v["ramp"],v["dramp"] = n[:4]
            elif k == "duty" and len(n) >= 2: v["duty"],v["duty_ramp"] = n[:2]
            elif k == "vib"  and len(n) >= 2: v["vibs"],v["vibspd"] = n[:2]
            elif k == "env"  and len(n) >= 4: v["atk"],v["sus"],v["punch"],v["dec"] = n[:4]
            elif k == "lpf"  and len(n) >= 3: v["lpf"],v["lpr"],v["lres"] = n[:3]
            elif k == "hpf"  and len(n) >= 2: v["hpf"],v["hpr"] = n[:2]
            elif k == "pha"  and len(n) >= 2: v["pho"],v["phr"] = n[:2]
            elif k == "arp"  and len(n) >= 2: v["arps"],v["arpm"] = n[:2]
    g = lambda x: ("%g" % x)
    with open(out, "w") as f:
        f.write("/* GENERATED by mote bake from %s.sfx — edit the .sfx sidecar, not this.\n"
                " *   Play: MoteSound %s = mote_sfx_bake(mote, &%s_sfx); */\n"
                "#ifndef MOTE_SFX_%s_H\n#define MOTE_SFX_%s_H\n#include \"mote_api.h\"\n\n"
                "static const MoteSfx %s_sfx = {\n    %d,  /* wave */\n"
                "    %s,%s,%s,%s, %s,%s,\n    %s,%s, %s,%s,%s,%s,\n    %s,%s,%s, %s,%s, %s,%s, %s,%s,\n};\n\n#endif\n"
                % (name, name, name, name, name, name, v["wave"],
                   g(v["base"]),g(v["limit"]),g(v["ramp"]),g(v["dramp"]),g(v["duty"]),g(v["duty_ramp"]),
                   g(v["vibs"]),g(v["vibspd"]),g(v["atk"]),g(v["sus"]),g(v["punch"]),g(v["dec"]),
                   g(v["lpf"]),g(v["lpr"]),g(v["lres"]),g(v["hpf"]),g(v["hpr"]),g(v["pho"]),g(v["phr"]),g(v["arps"]),g(v["arpm"])))
    print("[sfx] %s -> %s" % (os.path.basename(path), out))


def bake_wav(name, path, out):
    """assets/<name>.wav -> src/<name>.h : a `<name>_snd` MoteSound (raw int16
    PCM in flash). Matches Mote Studio's wav2snd. Play: mote->audio_play(&<name>_snd).
    For most SFX prefer the recipe path instead — assets/<name>.sfx -> <name>.sfx.h,
    played via mote->audio_play_sfx(&<name>_sfx) (streamed: tiny flash, ~0 RAM)."""
    import array
    b = open(path, "rb").read()
    off, ln, i = -1, 0, 12                                   # find the "data" sub-chunk
    while i + 8 <= len(b):
        cl = int.from_bytes(b[i+4:i+8], "little")
        if b[i:i+4] == b"data": off, ln = i + 8, cl; break
        i += 8 + cl + (cl & 1)
    if off < 0: off, ln = 44, len(b) - 44
    if off + ln > len(b): ln = len(b) - off
    n = max(0, ln // 2); pcm = array.array("h"); pcm.frombytes(b[off:off + n*2])
    L = ['/* GENERATED by mote bake (wav2snd) from %s — edit the .wav, not this. */' % os.path.basename(path),
         '#ifndef MOTE_SND_%s_H' % name, '#define MOTE_SND_%s_H' % name, '#include "mote_api.h"', '',
         'static const int16_t %s_pcm[%d] = {' % (name, n if n else 1)]
    for k in range(0, n, 16): L.append(','.join(str(v) for v in pcm[k:k+16]) + ',')
    if not n: L.append('0')
    L += ['};', 'static const MoteSound %s_snd = { %s_pcm, %d };' % (name, name, n if n else 1), '', '#endif']
    open(out, "w").write('\n'.join(L))
    print("[wav2snd] %s: %d samples -> %s" % (name, n, out))


def _png_rgb565(path):
    """PNG/BMP -> (w, h, [rgb565]) with alpha<128 -> magenta key 0xF81F."""
    import subprocess
    conv, ident = _magick()
    w, h = subprocess.check_output(ident + ["-format", "%w %h", path]).split(); w, h = int(w), int(h)
    raw = subprocess.check_output(conv + [path, "-depth", "8", "RGBA:-"])
    KEY = 0xF81F; px = []
    for i in range(w * h):
        r, g, b, a = raw[i*4], raw[i*4+1], raw[i*4+2], raw[i*4+3]
        if a < 128: px.append(KEY)
        else:
            v = ((r >> 3) << 11) | ((g >> 2) << 5) | (b >> 3); px.append(0xF81E if v == KEY else v)
    return w, h, px


def bake_tileset(name, tpath, gdir, out):
    """tilesets/<name>.tileset (+ its sheet png) -> src/<name>.tiles.h : a
    `<name>_at` MoteAutotile. The sidecar stores the LUT/xform/var weights, so the
    sheet pixels are the only thing baked from the PNG. Matches Mote Studio."""
    conf = {"tile": 16, "edge": 0, "nvar": 1, "sheet": ""}
    lut = [0]*256; xform = [0]*256; vw = [1]*8
    for line in open(tpath):
        t = line.split()
        if not t: continue
        k = t[0]
        if k == "sheet": conf["sheet"] = t[1]
        elif k in ("tile", "edge", "nvar"): conf[k] = int(t[1])
        elif k == "lut":    lut   = ([int(x) for x in t[1:]] + [0]*256)[:256]
        elif k == "xform":  xform = ([int(x) for x in t[1:]] + [0]*256)[:256]
        elif k == "vweight": vw   = ([int(x) for x in t[1:]] + [1]*8)[:8]
    ts = conf["tile"]; edge = conf["edge"]; nvar = conf["nvar"] if conf["nvar"] >= 1 else 1
    w, h, px = _png_rgb565(os.path.join(gdir, conf["sheet"]))
    L = ['/* GENERATED by mote bake from %s.tileset — edit the .tileset/sheet, not this. */' % name,
         '#ifndef MOTE_T_%s_H' % name, '#define MOTE_T_%s_H' % name, '#include "mote_tile.h"', '',
         'static const uint16_t %s_px[%d] = {' % (name, w*h)]
    for i in range(0, len(px), 16): L.append(','.join('0x%04x' % v for v in px[i:i+16]) + ',')
    L += ['};', 'static const MoteImage %s_img = { %s_px, %d, %d, 0xF81F, 0 };' % (name, name, w, h),
          'static const MoteAutotile %s_at = { &%s_img, %d, %d, {' % (name, name, ts, ts)]
    for i in range(0, 256, 16): L.append(','.join(str(v) for v in lut[i:i+16]) + ',')
    L.append('}, %d, %d, {' % (edge, nvar))
    for i in range(0, 256, 16): L.append(','.join(str(v) for v in xform[i:i+16]) + ',')
    L += ['}, {' + ','.join(str(v) for v in vw) + ',} };', '', '#endif']
    open(out, "w").write('\n'.join(L))
    print("[tiles] %s -> %s" % (os.path.basename(tpath), out))


def bake_level(name, lpath, out):
    """levels/<name>.level -> src/<name>.level.h : the layer map + a `<name>_draw`
    helper that calls scene2d_set_autotile_layers. Matches Mote Studio."""
    cols = rows = 0; layers = []; mp = []
    for line in open(lpath):
        t = line.split()
        if not t: continue
        if t[0] == "size":   cols, rows = int(t[1]), int(t[2])
        elif t[0] == "layer": layers.append(t[1])
        elif t[0] == "map":   mp = [int(x) for x in t[1:]]
    L = ['/* GENERATED by mote bake from %s.level — edit the .level, not this. */' % name,
         '#ifndef MOTE_LEVEL_%s_H' % name, '#define MOTE_LEVEL_%s_H' % name, '#include "mote_api.h"']
    for ly in layers: L.append('#include "%s.tiles.h"' % ly)
    L += ['', '#define %s_COLS %d' % (name, cols), '#define %s_ROWS %d' % (name, rows),
          'static const uint8_t %s_map[%d] = {' % (name, cols*rows)]
    for r in range(rows): L.append(','.join(str(mp[r*cols+c]) for c in range(cols)) + ',')
    L += ['};', 'static const MoteAutotile *%s_tiles[%d] = { %s };'
          % (name, len(layers), ', '.join('&%s_at' % ly for ly in layers)),
          'static inline void %s_draw(const MoteApi *m){ m->scene2d_set_autotile_layers(%s_map, %s_COLS, %s_ROWS, %s_tiles, %d); }'
          % (name, name, name, name, name, len(layers)), '', '#endif']
    open(out, "w").write('\n'.join(L))
    print("[level] %s -> %s" % (os.path.basename(lpath), out))


def bake_anims(name, apath, gdir, out):
    """anims/<name>.anims (+ its sheet png) -> src/<name>.anim.h : a tightly-packed
    atlas of only the cells the clips use + MoteAnimClip/Frame tables. Matches the
    Studio's Anim-tab bake (atlas repack, cell remap, an_fdur durations)."""
    import subprocess
    sheet = None; tw = th = 16; clips = []; cur = None
    for line in open(apath):
        t = line.split()
        if not t: continue
        if t[0] == "sheet": sheet = t[1]
        elif t[0] == "tile": tw, th = int(t[1]), int(t[2])
        elif t[0] == "clip":
            cur = {"name": t[1], "loop": int(t[2]), "fps": int(t[3]), "pvx": int(t[4]), "pvy": int(t[5]), "fr": []}
            clips.append(cur)
        elif t[0] == "f" and cur is not None:
            ev = t[3] if len(t) > 3 else "-"
            cur["fr"].append({"cell": int(t[1]), "dur": int(t[2]), "ev": "" if ev == "-" else ev})
    conv, ident = _magick(); sp = os.path.join(gdir, sheet)
    w, h = subprocess.check_output(ident + ["-format", "%w %h", sp]).split(); w, h = int(w), int(h)
    raw = subprocess.check_output(conv + [sp, "-depth", "8", "RGBA:-"]); KEY = 0xF81F; px = []
    for i in range(w*h):
        r, g, b, a = raw[i*4], raw[i*4+1], raw[i*4+2], raw[i*4+3]
        px.append(KEY if (a < 128 or (r > 200 and g < 60 and b > 200)) else ((r>>3)<<11)|((g>>2)<<5)|(b>>3))
    oldcols = max(1, w // tw)
    remap = {}; used = []
    for c in clips:
        for fr in c["fr"]:
            cl = fr["cell"] if 0 <= fr["cell"] < 8192 else 0
            if cl not in remap: remap[cl] = len(used); used.append(cl)
    if not used: used = [0]; remap = {0: 0}
    nused = len(used); pc = 1
    while pc*pc < nused: pc += 1
    pr = (nused + pc - 1) // pc; AW, AH = pc*tw, pr*th; atlas = [KEY]*(AW*AH)
    for kk, oc in enumerate(used):
        scx, scy, dcx, dcy = (oc % oldcols)*tw, (oc // oldcols)*th, (kk % pc)*tw, (kk // pc)*th
        for y in range(th):
            for x in range(tw):
                sx, sy = scx+x, scy+y
                atlas[(dcy+y)*AW + dcx+x] = px[sy*w+sx] if (sx < w and sy < h) else KEY
    L = ['/* GENERATED by mote bake from %s.anims — edit the .anims/sheet, not this. */' % name,
         '#ifndef MOTE_ANIM_%s_H' % name, '#define MOTE_ANIM_%s_H' % name, '#include "mote_anim.h"', '',
         'static const uint16_t %s_px[%d] = {' % (name, AW*AH)]
    for i in range(0, len(atlas), 16): L.append(','.join('0x%04x' % v for v in atlas[i:i+16]) + ',')
    L += ['};', 'static const MoteImage %s_img = { %s_px, %d, %d, 0xF81F, 0 };' % (name, name, AW, AH),
          'static const MoteAnimSheet %s_sheet = { &%s_img, %d, %d };' % (name, name, tw, th), '']
    for c in clips:
        nfr = len(c["fr"])
        L.append('static const MoteAnimFrame %s_%s_fr[%d] = {' % (name, c["name"], nfr if nfr else 1))
        if not nfr: L.append('  {0,125,0},')
        for fr in c["fr"]:
            oc = fr["cell"] if 0 <= fr["cell"] < 8192 else 0; nc = remap.get(oc, 0)
            dur = fr["dur"] if fr["dur"] else (1000 // c["fps"] if c["fps"] > 0 else 125)
            L.append('  {%d,%d,"%s"},' % (nc, dur, fr["ev"]) if fr["ev"] else '  {%d,%d,0},' % (nc, dur))
        L += ['};', 'static const MoteAnimClip %s_%s = { "%s", %s_%s_fr, %d, %d, %d, %d };'
              % (name, c["name"], c["name"], name, c["name"], nfr if nfr else 1, c["loop"], c["pvx"], c["pvy"]), '']
    L.append('#endif'); open(out, "w").write('\n'.join(L))
    print("[anim] %s -> %s (%d clips, %d cells)" % (os.path.basename(apath), out, len(clips), nused))


def cmd_bake(args):
    """Bake assets/* into src/<name>.h headers to #include — full parity with the
    Studio's bake (no IDE needed).

    PNG/BMP -> <name>_img MoteImage · OBJ -> <name>_mesh · STL -> chunked MoteModel ·
    OBJ+.rig -> MoteRig · .sfx -> <name>.sfx.h MoteSfx · .wav -> <name>.h MoteSound ·
    tilesets/*.tileset (+sheet) -> <name>.tiles.h MoteAutotile · levels/*.level ->
    <name>.level.h · game-root icon.png -> src/icon.h."""
    import tempfile
    d = args.dir
    src = os.path.join(d, "src")
    assets = os.path.join(d, "assets")
    # Recurse into asset subfolders; header names stay flat (src/<base>.h), so
    # keep asset filenames unique across subfolders.
    files = []
    for root, dirs, fs in os.walk(assets):
        dirs[:] = [x for x in dirs if x != "build" and not x.startswith(".")]
        for f in sorted(fs):
            if not f.startswith("."):
                files.append(os.path.join(root, f))
    for ic in ("icon.png", "icon.bmp"):                      # launcher icon (game root)
        p = os.path.join(d, ic)
        if os.path.isfile(p):
            bake_icon(p, os.path.join(src, "icon.h")); break
    objs = [f for f in files if f.endswith(".obj")]
    stls = [f for f in files if f.lower().endswith(".stl")]
    # A PNG that backs a WANG16/auto-tileset (tilesets/<name>.tileset) is baked as a
    # <name>.tiles.h by the Studio Tiles tab, not as a plain <name>_img — so skip it here.
    tiled = set()
    tdir = os.path.join(d, "tilesets")
    if os.path.isdir(tdir):
        for t in os.listdir(tdir):
            if t.endswith(".tileset"): tiled.add(os.path.splitext(t)[0])
    # A PNG that sits next to a model with the same basename (model.obj/model.stl)
    # is that model's TEXTURE SIDECAR (assigned in the Studio MESH/RIG view), baked
    # INTO the mesh header by obj2mesh/stl2mesh — never as a standalone image.
    models = set(os.path.splitext(os.path.join(os.path.dirname(f),
                 os.path.basename(f)))[0] for f in objs + stls)
    imgs = [f for f in files if f.lower().endswith((".png", ".bmp"))
            and os.path.splitext(os.path.basename(f))[0] not in tiled
            and os.path.splitext(f)[0] not in models]
    sfxs = [f for f in files if f.lower().endswith(".sfx")]
    wavs = [f for f in files if f.lower().endswith(".wav")]
    tsets = sorted(os.path.join(tdir, t) for t in os.listdir(tdir)) if os.path.isdir(tdir) else []
    tsets = [t for t in tsets if t.endswith(".tileset")]
    ldir = os.path.join(d, "levels")
    lvls = sorted(os.path.join(ldir, t) for t in os.listdir(ldir)) if os.path.isdir(ldir) else []
    lvls = [t for t in lvls if t.endswith(".level")]
    adir = os.path.join(d, "anims")
    anims = sorted(os.path.join(adir, t) for t in os.listdir(adir)) if os.path.isdir(adir) else []
    anims = [t for t in anims if t.endswith(".anims")]
    if not (objs or stls or imgs or sfxs or wavs or tsets or lvls or anims):
        print("mote: no bakeable assets in %s" % d); return

    # Warn on base-name collisions: assets of different types that bake to the same
    # src/<base>.h (e.g. shell.obj and shell.wav) — last one wins and silently clobbers
    # the other. (Rigged OBJs emit <base>.rig.h, so they don't collide on <base>.h.)
    rigged = set(os.path.splitext(o)[0] for o in objs
                 if os.path.isfile(os.path.splitext(o)[0] + ".rig"))
    _hdr_src = {}
    for f in [o for o in objs if os.path.splitext(o)[0] not in rigged] + stls + imgs + wavs:
        b = os.path.splitext(os.path.basename(f))[0]
        if b in _hdr_src and _hdr_src[b] != f:
            print("WARNING: %s and %s both bake to src/%s.h - rename one "
                  "(asset base names must be unique across types)"
                  % (os.path.basename(_hdr_src[b]), os.path.basename(f), b))
        else:
            _hdr_src.setdefault(b, f)

    def tool_for(s, exe):
        t = os.path.join(tempfile.gettempdir(), exe)
        src = os.path.join(ROOT, "tools", s)
        dep = os.path.join(ROOT, "tools", "tex_embed.h")   # shared header of the mesh bakers
        newest = max(os.path.getmtime(p) for p in (src, dep) if os.path.isfile(p))
        # Rebuild when the binary is missing OR older than the source/shared header,
        # so editing a baker (or tex_embed.h) doesn't silently re-bake with a stale tool.
        if not os.path.isfile(t) or os.path.getmtime(t) < newest:
            run(["gcc", "-O2", "-I", os.path.join(ROOT, "studio", "third_party"),
                 src, "-lm", "-o", t])
        return t

    for o in objs:
        name = os.path.splitext(os.path.basename(o))[0]
        rig = os.path.join(os.path.dirname(o), name + ".rig")
        if os.path.isfile(rig):              # multi-object OBJ + .rig sidecar -> a MoteRig
            rt = tool_for("obj2rig.c", "mote_obj2rig")
            run([rt, name, o, os.path.join(src, name + ".rig.h"), rig])
        else:                                # plain OBJ -> a single Mesh
            ot = tool_for("obj2mesh.c", "mote_obj2mesh")
            run([ot, name, o, os.path.join(src, name + ".h")])
    if stls:
        st = tool_for("stl2mesh.c", "mote_stl2mesh")
        budget = str(getattr(args, "budget", None) or 1500)
        for s in stls:
            name = os.path.splitext(os.path.basename(s))[0]
            run([st, name, s, os.path.join(src, name + ".h"), budget])
    for im in imgs:
        name = os.path.splitext(os.path.basename(im))[0]
        bake_image(name, im, os.path.join(src, name + ".h"))
    for sx in sfxs:
        name = os.path.splitext(os.path.basename(sx))[0]
        bake_sfx(name, sx, os.path.join(src, name + ".sfx.h"))
    for wv in wavs:
        name = os.path.splitext(os.path.basename(wv))[0]
        bake_wav(name, wv, os.path.join(src, name + ".h"))
    for ts in tsets:
        name = os.path.splitext(os.path.basename(ts))[0]
        bake_tileset(name, ts, d, os.path.join(src, name + ".tiles.h"))
    for lv in lvls:
        name = os.path.splitext(os.path.basename(lv))[0]
        bake_level(name, lv, os.path.join(src, name + ".level.h"))
    for an in anims:
        name = os.path.splitext(os.path.basename(an))[0]
        bake_anims(name, an, d, os.path.join(src, name + ".anim.h"))


def cmd_studio(args):
    """Build + launch the Studio IDE (opens to the game library)."""
    studio = os.path.join(ROOT, "build_host", "mote_studio")
    bh = os.path.join(ROOT, "build_host")
    if os.path.isdir(bh):
        run(["cmake", "--build", bh, "--target", "mote_studio", "-j8"])
    elif not os.path.isfile(studio):
        sys.exit("mote: build the host first:\n  cmake -B build_host -S . && cmake --build build_host -j8")
    os.chdir(ROOT)                                   # Studio shells ./tools/mote + scans examples/
    argv = [studio]
    if getattr(args, "mode", None):                  # `mote studio calibrate` -> the one-off screen rig
        argv.append(args.mode)
    os.execv(studio, argv)


def cmd_run(args):
